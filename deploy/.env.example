# Copiar a deploy/.env y completar (no commitear .env):
#   cp deploy/.env.example deploy/.env
#
# Docker Compose lee variables con --env-file deploy/.env (ver deploy/README.md).

# --- Secrets ---
# Requerido para Analizar (fast-path Gemini) en el servicio web
GEMINI_API_KEY=

# --- SEACE / Alfresco egress ---
# En VPS/datacenter suele ser obligatorio. La app prioriza SEACE_HTTP_PROXY,
# luego HTTP_PROXY, luego http_proxy en config.yaml.
SEACE_HTTP_PROXY=http://server.maczona.com:18081
# HTTP_PROXY=
# HTTPS_PROXY=

# --- Base de datos (opcional) ---
# Por defecto SQLite vía config.yaml (database_url). Postgres opt-in:
#   docker compose --env-file deploy/.env \
#     -f deploy/docker-compose.yml -f deploy/docker-compose.postgres.yaml up -d
# SQLite y Postgres no migran datos entre sí; ver deploy/README.md.
# DATABASE_URL=postgresql+psycopg://seace:seace@db:5432/seace

# --- Rutas dentro del contenedor (defaults OK) ---
TENDER_REPO_ROOT=/app
CONFIG_PATH=/app/config.yaml
TENANT_ID=default

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=tender-workflows
WEB_PORT=8080

# --- Postgres dev (solo stack local con servicio db) ---
POSTGRES_USER=seace
POSTGRES_PASSWORD=seace
POSTGRES_DB=seace
