{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://infinitek.local/tender_procurement/plan_pages_analysis.schema.json",
  "title": "Plan/diagram page visual analysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_pdf", "model", "pages"],
  "properties": {
    "schema_version": { "const": "0.1" },
    "source_pdf": { "type": "string" },
    "model": { "type": "string" },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page_analysis" }
    }
  },
  "$defs": {
    "page_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "is_plan_or_diagram",
        "exclude_from_ocr",
        "identifier_or_title",
        "visual_type",
        "summary",
        "procurement_relevant_info",
        "visible_text_or_codes",
        "limitations",
        "confidence"
      ],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "is_plan_or_diagram": { "type": "boolean" },
        "exclude_from_ocr": {
          "type": "boolean",
          "description": "True only when the page should be replaced by a text summary before the generic OCR/Markdown converter. Keep false for large tables or pages whose normal OCR is preferable."
        },
        "identifier_or_title": {
          "type": ["string", "null"],
          "description": "Visible plan/page identifier or title, e.g. 'Plano instalaciones eléctricas página 1', 'SPYL-SV-T-0300', or the title block text."
        },
        "visual_type": { "type": "string" },
        "summary": { "type": "string" },
        "procurement_relevant_info": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visible_text_or_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "limitations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    }
  }
}
