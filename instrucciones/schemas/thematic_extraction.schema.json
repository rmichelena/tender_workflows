{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "thematic_extraction.schema.json",
  "title": "Tender procurement thematic extraction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "axis_id",
    "axis_name",
    "source_md_path",
    "document_index_path",
    "method",
    "entries",
    "coverage",
    "uncertainties",
    "schema_feedback"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "document_id": { "type": "string", "minLength": 1 },
    "axis_id": { "type": "string", "minLength": 1 },
    "axis_name": { "type": "string", "minLength": 1 },
    "source_md_path": { "type": "string", "minLength": 1 },
    "document_index_path": { "type": "string", "minLength": 1 },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunking_strategy", "target_chunk_lines", "read_order", "notes"],
      "properties": {
        "chunking_strategy": { "type": "string" },
        "target_chunk_lines": { "type": "integer", "minimum": 1 },
        "read_order": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections_read", "line_ranges_read", "coverage_notes"],
      "properties": {
        "sections_read": {
          "type": "array",
          "items": { "type": "string" }
        },
        "line_ranges_read": {
          "type": "array",
          "items": { "$ref": "#/$defs/line_range" }
        },
        "coverage_notes": { "type": "string" }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertainty" }
    },
    "schema_feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sufficient", "suggested_changes", "notes"],
      "properties": {
        "sufficient": { "type": "boolean" },
        "suggested_changes": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "line_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line_start", "line_end"],
      "properties": {
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "entry_type",
        "mention_type",
        "phase",
        "description",
        "source_line_start",
        "source_line_end",
        "section_path",
        "evidence_excerpt",
        "interpretation_notes",
        "dedupe_context",
        "cross_axis_notes",
        "confidence"
      ],
      "properties": {
        "entry_id": { "type": "string", "minLength": 1 },
        "entry_type": { "type": "string", "minLength": 1 },
        "mention_type": { "type": "string", "enum": ["explicit", "implied"] },
        "phase": {
          "type": "string",
          "enum": ["proposal", "contract_signature", "execution_pre_acceptance", "post_acceptance", "general", "unclear"]
        },
        "description": { "type": "string", "minLength": 1 },
        "source_line_start": { "type": "integer", "minimum": 1 },
        "source_line_end": { "type": "integer", "minimum": 1 },
        "section_path": { "type": "array", "items": { "type": "string" } },
        "evidence_excerpt": { "type": "string", "minLength": 1 },
        "interpretation_notes": { "type": "string" },
        "dedupe_context": { "type": "string" },
        "cross_axis_notes": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line_start", "line_end", "description", "severity"],
      "properties": {
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    }
  }
}
