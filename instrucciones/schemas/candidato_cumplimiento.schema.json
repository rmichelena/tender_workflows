{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "candidato_cumplimiento.schema.json",
  "title": "Matriz de cumplimiento por candidato (v0.2)",
  "type": "object",
  "required": ["item_id", "candidato_num", "marca", "modelo", "estado", "cumplimiento", "resumen"],
  "properties": {
    "item_id": { "type": "string" },
    "candidato_num": { "type": "integer", "minimum": 1 },
    "marca": { "type": "string" },
    "modelo": { "type": "string" },
    "part_number": { "type": "string" },
    "estado": { "type": "string", "enum": ["VALIDO", "CONDICIONADO"] },
    "url_fabricante": { "type": "string", "format": "uri" },
    "url_datasheet": { "type": "string" },
    "datasheet_parsed_path": { "type": "string" },
    "fuentes_consultadas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cumplimiento": {
      "type": "array",
      "description": "Una entrada por cada requerimiento del ítem (sin omitir ninguno)",
      "items": {
        "type": "object",
        "required": ["req_id", "texto_verbatim", "resultado", "valor_encontrado", "referencias"],
        "properties": {
          "req_id": { "type": "string" },
          "texto_verbatim": { "type": "string" },
          "resultado": {
            "type": "string",
            "enum": ["OK", "PARCIAL", "NO_CUMPLE"],
            "description": "Mapeo emoji: OK=✅, PARCIAL=⚠️, NO_CUMPLE=❌"
          },
          "subtipo_parcial": {
            "type": ["string", "null"],
            "enum": [null, "parcial_sin_info", "parcial_cumple_parcial", "parcial_inconsistente"],
            "description": "Solo requerido cuando resultado=PARCIAL. null cuando resultado=OK o NO_CUMPLE. Distingue: (a) sin información en datasheet, (b) cumple solo con accesorio/config adicional, (c) datasheet inconsistente con sí mismo o con página web."
          },
          "valor_encontrado": { "type": "string" },
          "referencias": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "resumen": {
      "type": "object",
      "required": ["cumple", "incumple", "total"],
      "properties": {
        "cumple": { "type": "integer", "minimum": 0 },
        "parcial_sin_info": { "type": "integer", "minimum": 0 },
        "parcial_cumple_parcial": { "type": "integer", "minimum": 0 },
        "parcial_inconsistente": { "type": "integer", "minimum": 0 },
        "incumple": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "notas": { "type": "string" }
  }
}
