{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "staging_manifest.schema.json",
  "title": "StagingManifest",
  "description": "Expediente preparado en etapa B: documentos seleccionados, uploads y aclaraciones declaradas.",
  "type": "object",
  "required": ["version", "process_id", "source", "selected_documents", "prepared_at"],
  "properties": {
    "version": { "type": "string", "const": "0.1" },
    "process_id": { "type": "integer" },
    "tenant_id": { "type": "string", "default": "default" },
    "source": {
      "type": "string",
      "description": "Canal de ingesta: seace, manual, adp_portal, ..."
    },
    "selected_documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_path", "dest_path"],
        "properties": {
          "source_path": { "type": "string" },
          "dest_path": { "type": "string" },
          "original_name": { "type": "string" },
          "sha256": { "type": "string" },
          "input_bucket": {
            "type": "string",
            "enum": ["docs_proceso", "docs_usuario"],
            "default": "docs_proceso"
          },
          "input_bucket_label": { "type": "string" },
          "document_role": {
            "type": "string",
            "enum": [
              "bases_iniciales",
              "aclaraciones",
              "bases_aclaradas",
              "especificaciones_tecnicas",
              "otros"
            ]
          },
          "document_role_label": { "type": "string" },
          "included": { "type": "boolean", "default": true }
        }
      }
    },
    "uploads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dest_path", "original_name"],
        "properties": {
          "dest_path": { "type": "string" },
          "original_name": { "type": "string" },
          "sha256": { "type": "string" },
          "input_bucket": {
            "type": "string",
            "enum": ["docs_proceso", "docs_usuario"],
            "default": "docs_usuario"
          },
          "input_bucket_label": { "type": "string" },
          "document_role": {
            "type": "string",
            "enum": [
              "bases_iniciales",
              "aclaraciones",
              "bases_aclaradas",
              "especificaciones_tecnicas",
              "otros"
            ]
          },
          "document_role_label": { "type": "string" }
        }
      }
    },
    "clarifications": {
      "type": "array",
      "description": "Archivos declarados como aclaración/addenda/enmienda por el usuario (Gate 0.a UI)",
      "items": {
        "type": "object",
        "required": ["file", "clarification_type"],
        "properties": {
          "file": { "type": "string" },
          "clarification_type": {
            "type": "string",
            "enum": ["aclaracion", "addenda", "enmienda"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "portfolio_scenario": {
      "type": "object",
      "description": "Escenario A/B/C deducido a partir de la clasificación documental y cronograma.",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "initial_bases",
            "integrate_clarifications",
            "verify_integrated_bases",
            "technical_specs_only"
          ]
        },
        "seed_variant": {
          "type": "string",
          "enum": [
            "initial_bases",
            "bases_plus_clarifications",
            "bases_clarifications_integrated"
          ]
        },
        "recommended_action": { "type": "string" },
        "queries_window": {
          "type": "string",
          "enum": ["open", "closed", "unknown"]
        },
        "document_roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "free_reader_profile": {
      "type": "object",
      "properties": {
        "profile_id": { "type": "string" },
        "sections_requested": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prompt_version": { "type": "string" }
      }
    },
    "notes": { "type": "string" },
    "prepared_at": { "type": "string", "format": "date-time" },
    "prepared_by": { "type": "string" }
  }
}
