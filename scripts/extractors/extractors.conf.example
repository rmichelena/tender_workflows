# tender_procurement configuration
# Copy to extractors.conf and customize. See README for details.

[docai]
# Google Cloud project ID (numeric)
project_id = 839375208239

# Document AI processor location
location = us

# Layout Parser processor ID
processor_id = b8ea939312a8ff4

# Processor version (empty = stable/v1.0, or specify e.g. pretrained-layout-parser-v1.6-2026-01-13)
# Available versions: pretrained-layout-parser-v1.6-2026-01-13 (rc), pretrained-layout-parser-v1.5-2025-08-25,
#   pretrained-layout-parser-v1.5-pro-2025-08-25, pretrained-layout-parser-v1.0-2024-06-03 (stable)
processor_version = pretrained-layout-parser-v1.6-2026-01-13

# GCS bucket for batch mode input/output
gcs_bucket = hermoberto

# OAuth token file path
token_path = google_token_personal.json

# Online mode: max pages per request (API limit = 15)
online_page_limit = 15

# Chunk size for DocAI chunking config
chunk_size = 500

# Enable image annotation (verbose descriptions of logos, stamps, diagrams)
# Default: false — image annotations are noise for text extraction.
# Set true for second-pass classification of diagrams vs logos/stamps.
enable_image_annotation = false

# Filter headers/footers from markdown output (default: true)
# v1.6+ detects header/footer blocks via semantic_type.
filter_headers_footers = true

# Batch polling interval (seconds)
poll_interval = 20

# Batch max wait time (seconds)
max_wait = 3600
